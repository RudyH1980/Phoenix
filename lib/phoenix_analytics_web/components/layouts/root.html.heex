<!DOCTYPE html>
<html lang="nl" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content="Neo Analytics — privacy-first web analytics zonder cookies. Inzicht in paginaweergaven, bezoekers, apparaten en meer."
    />
    <link rel="canonical" href="https://phoenix-analytics.fly.dev/" />
    <meta property="og:title" content="Neo Analytics — Privacy-First Web Analytics" />
    <meta
      property="og:description"
      content="Cookieloze analytics zonder tracking. Inzicht in paginaweergaven, bezoekers, apparaten en meer."
    />
    <meta property="og:url" content="https://phoenix-analytics.fly.dev/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Neo Analytics" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Neo Analytics — Privacy-First Web Analytics" />
    <meta
      name="twitter:description"
      content="Cookieloze analytics zonder tracking. Inzicht in paginaweergaven, bezoekers, apparaten en meer."
    />
    <script type="application/ld+json" nonce={assigns[:csp_nonce]}>
      {"@context":"https://schema.org","@type":"SoftwareApplication","name":"Neo Analytics","description":"Privacy-first web analytics zonder cookies","applicationCategory":"WebApplication","url":"https://phoenix-analytics.fly.dev","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"}}
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0d1117" />
    <.live_title default="Neo Analytics" suffix=" · Neo Analytics">
      {assigns[:page_title]}
    </.live_title>

    <%!-- Flash prevention: zet thema vóór CSS laadt (voorkomt witte flits) --%>
    <script nonce={assigns[:csp_nonce]}>
      (function(){var t=localStorage.getItem("pa-theme");if(t==="light"||t==="dark")document.documentElement.setAttribute("data-theme",t);})();
    </script>

    <%!-- Critical inline CSS: voorkom FOUC, geen render-blocking --%>
    <style nonce={assigns[:csp_nonce]}>
      *,*::before,*::after{box-sizing:border-box}
      html{scroll-behavior:smooth}
      body{margin:0;background:oklch(12% 0.016 250);color:oklch(90% 0.01 250);font-family:system-ui,sans-serif;-webkit-font-smoothing:antialiased}
      [data-theme="light"] body,[data-theme="light"]{background:oklch(97% 0.005 240);color:oklch(16% 0.015 250)}
    </style>

    <%!-- CSS preload: hints de browser vroeg, laadt non-blocking --%>
    <link rel="preload" href={~p"/assets/css/app.css"} as="style" />
    <link rel="stylesheet" href={~p"/assets/css/app.css"} />

    <%!-- JS defer: nooit render-blocking --%>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js"}
      nonce={assigns[:csp_nonce]}
    >
    </script>
  </head>
  <body>
    <canvas id="pa-matrix-canvas" aria-hidden="true" style="display:none;"></canvas>
    <%= if assigns[:is_demo] do %>
      <div class="pa-demo-topbar" role="alert">
        <span class="pa-demo-badge">DEMO</span>
        <span>Je bekijkt een demo account met gesimuleerde data van 3 fictieve websites.</span>
        <a href="/login" class="pa-demo-topbar-exit">
          Eigen account aanmaken →
        </a>
      </div>
    <% end %>
    <main>
      {@inner_content}
    </main>
    <footer class="pa-footer">
      Neo Analytics v{Application.spec(:phoenix_analytics, :vsn)}
    </footer>
    <%!-- Pill togglers worden door JavaScript geïnjecteerd (#pa-pill-togglers) --%>
  </body>
</html>
