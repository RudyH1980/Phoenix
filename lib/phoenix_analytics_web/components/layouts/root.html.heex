<!DOCTYPE html>
<html lang="nl" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Phoenix Analytics" suffix=" · Phoenix Analytics">
      {assigns[:page_title]}
    </.live_title>

    <%!-- Flash prevention: zet thema vóór CSS laadt (voorkomt witte flits) --%>
    <script>
      (function(){var t=localStorage.getItem("pa-theme");if(t==="light"||t==="dark")document.documentElement.setAttribute("data-theme",t);})();
    </script>

    <%!-- Critical inline CSS: voorkom FOUC, geen render-blocking --%>
    <style nonce={assigns[:csp_nonce]}>
      *,*::before,*::after{box-sizing:border-box}
      html{scroll-behavior:smooth}
      body{margin:0;background:oklch(12% 0.016 250);color:oklch(90% 0.01 250);font-family:system-ui,sans-serif;-webkit-font-smoothing:antialiased}
      [data-theme="light"] body,[data-theme="light"]{background:oklch(97% 0.005 240);color:oklch(16% 0.015 250)}
    </style>

    <link rel="stylesheet" href={~p"/assets/css/app.css"} />

    <%!-- JS defer: nooit render-blocking --%>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js"}
      nonce={assigns[:csp_nonce]}
    >
    </script>
  </head>
  <body>
    {@inner_content}
    <button
      id="pa-theme-toggle"
      onclick="(function(){var h=document.documentElement;var t=h.getAttribute('data-theme')==='dark'?'light':'dark';h.setAttribute('data-theme',t);localStorage.setItem('pa-theme',t);var btn=document.getElementById('pa-theme-toggle');btn.setAttribute('aria-label',t==='dark'?'Schakel naar licht thema':'Schakel naar donker thema');btn.setAttribute('title',t==='dark'?'Schakel naar licht thema':'Schakel naar donker thema');})()"
      aria-label="Schakel naar licht thema"
      title="Schakel naar licht thema"
    >
      <svg
        id="pa-icon-moon"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75 9.75 9.75 0 0 1 8.25 6 9.72 9.72 0 0 1 9 2.248a9.75 9.75 0 1 0 12.752 12.754z" />
      </svg>
      <svg
        id="pa-icon-sun"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z" />
      </svg>
    </button>
  </body>
</html>
